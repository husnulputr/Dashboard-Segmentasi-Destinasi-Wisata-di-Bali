# 3. LOAD DATA (SESUAI FOLDER KAMU)
data <- read_csv("ML CLUSTERING/tourism_dataset.csv")
# 4. CEK DATA
cat("Struktur Data:\n")
str(data)
cat("\nSummary Data:\n")
summary(data)
# 5. PREPROCESSING
# Ambil hanya variabel numerik sesuai jurnal
data_clean <- dplyr::select(data, Visitors, Rating, Revenue)
# 6. CEK MISSING VALUE
cat("\nMissing Value:\n")
colSums(is.na(data_clean))
# Hapus jika ada NA
data_clean <- na.omit(data_clean)
# 7. NORMALISASI (Z-SCORE)
data_scaled <- scale(data_clean)
# 8. DETEKSI OUTLIER (IQR)
Q1 <- apply(data_scaled, 2, quantile, 0.25)
Q3 <- apply(data_scaled, 2, quantile, 0.75)
IQR_val <- Q3 - Q1
lower_bound <- Q1 - 1.5 * IQR_val
upper_bound <- Q3 + 1.5 * IQR_val
# Filter data tanpa outlier
data_no_outlier <- data_scaled[
apply(data_scaled, 1, function(x) all(x >= lower_bound & x <= upper_bound)),
]
cat("\nJumlah data setelah hapus outlier:", nrow(data_no_outlier), "\n")
# 9. DISTANCE MATRIX
dist_matrix <- dist(data_no_outlier, method = "euclidean")
# 10. HIERARCHICAL CLUSTERING (COMPLETE LINKAGE)
hc <- hclust(dist_matrix, method = "complete")
# 11. VISUALISASI DENDROGRAM
plot(hc,
main = "Dendrogram Hierarchical Clustering",
xlab = "",
sub = "",
cex = 0.7)
clusters <- cutree(hc, k = k)
# 12. MENENTUKAN JUMLAH CLUSTER
k <- 3
clusters <- cutree(hc, k = k)
# 13. TAMBAHKAN LABEL CLUSTER
data_clustered <- as.data.frame(data_no_outlier)
data_clustered$Cluster <- as.factor(clusters)
# 14. VISUALISASI CLUSTER
fviz_cluster(list(data = data_no_outlier, cluster = clusters),
ellipse.type = "convex",
palette = "jco",
ggtheme = theme_minimal(),
main = "Visualisasi Cluster Hierarchical")
# Silhouette Score
sil <- silhouette(clusters, dist_matrix)
avg_silhouette <- mean(sil[, 3])
# Davies-Bouldin Index
db <- cluster.stats(dist_matrix, clusters)
db_index <- db$davies.bouldin
# 16. OUTPUT EVALUASI
cat("\n===== HASIL EVALUASI =====\n")
cat("Silhouette Score :", avg_silhouette, "\n")
cat("Davies-Bouldin Index :", db_index, "\n")
# 17. ANALISIS RATA-RATA TIAP CLUSTER
